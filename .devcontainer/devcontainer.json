{
  "name": "Manim Cloud IDE",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "muted Kirsten.vscode-animation",
        "visualstudioexptteam.vscodeintellicode",
        "usernamehw.errorlens",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.fontSize": 14,
        "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
        "editor.lineHeight": 1.6,
        "editor.letterSpacing": 0.5,
        "editor.fontLigatures": true,
        "editor.minimap.enabled": true,
        "editor.renderLineHighlight": "all",
        "editor.cursorBlinking": "smooth",
        "editor.smoothScrolling": true,
        "workbench.colorTheme": "Monokai",
        "workbench.iconTheme": "material-icon-theme",
        "terminal.integrated.fontSize": 13,
        "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "python.analysis.typeCheckingMode": "basic",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.linting.flake8Enabled": true,
        "python.formatting.provider": "black",
        "python.testing.pytestEnabled": true,
        "jupyter.askForKernelRestart": false,
        "prettier.requireConfig": true,
        "prettier.tabWidth": 4
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && apt-get update && apt-get install -y ffmpeg texlive-latex-extra texlive-fonts-extra cm-super dvipng && fc-cache -fv",
  "portsAttributes": {
    "8888": {
      "label": "Jupyter",
      "onForward": "notify"
    },
    "6060": {
      "label": "Manim Preview",
      "onForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}